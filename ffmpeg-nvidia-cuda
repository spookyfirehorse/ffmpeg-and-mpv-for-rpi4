#!/bin/bash
# FFmpeg Ultimate Build Script für Skylake + NVIDIA NVDEC/NVENC + Vulkan/Libplacebo

# 1. System-Abhängigkeiten installieren
echo "--- Installiere Abhängigkeiten ---"
apt update
apt install -y build-essential nasm pkg-config git libva-dev libvdpau-dev \
  libpulse-dev libjack-jackd2-dev libgcrypt20-dev libvulkan-dev libplacebo-dev \
  libfreetype6-dev libharfbuzz-dev libfribidi-dev libfdk-aac-dev libmp3lame-dev \
  libopus-dev libvorbis-dev libvpx-dev libsnappy-dev libsoxr-dev libbs2b-dev \
  libmysofa-dev librubberband-dev gnutls-dev

# 2. FFmpeg Source (falls noch nicht im Verzeichnis)
if [ ! -f configure ]; then
    echo "Fehler: Bitte starte das Skript im FFmpeg Source-Verzeichnis!"
    exit 1
fi


# 5. Kompilieren
echo "--- Kompiliere FFmpeg (nutze $(nproc) Kerne) ---"
make -j$(nproc)

# 6. Installation
echo "--- Installiere systemweit ---"
make install
ldconfig

# 7. Verifizierung
echo "--- Build-Check ---"
ffmpeg -version | grep "built with"
ffmpeg -hwaccels | grep -E "cuda|vulkan"
ldd $(which ffmpeg) | grep -E "nv|cuda|vulkan|placebo|pulse|jack"

echo "FERTIG! Dein optimierter FFmpeg Build ist einsatzbereit."



